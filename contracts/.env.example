# =============================================================================
# Hey Elsa & The AI Council — Smart Contract Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — it is already in .gitignore.
# =============================================================================


# -----------------------------------------------------------------------------
# DEPLOYER WALLET
# -----------------------------------------------------------------------------

# Private key of the deployer/admin wallet (without 0x prefix).
# This wallet will receive DEFAULT_ADMIN_ROLE on all contracts.
# Use a dedicated deployer wallet — never your personal hot wallet.
DEPLOYER_PRIVATE_KEY=your_deployer_private_key_here

# Address of the deployer/admin wallet (derived from DEPLOYER_PRIVATE_KEY).
# Used in deploy scripts when specifying the admin address explicitly.
DEPLOYER_ADDRESS=0xYourDeployerAddressHere


# -----------------------------------------------------------------------------
# ELSA SIGNER — MPC Co-Signer Wallet
# -----------------------------------------------------------------------------

# Private key of the initial ELSA_SIGNER_ROLE wallet.
# In production this is replaced by your MPC wallet cluster.
# Used in tests and staging deployments only.
ELSA_SIGNER_PRIVATE_KEY=your_elsa_signer_private_key_here

# Address of the initial ELSA_SIGNER wallet.
ELSA_SIGNER_ADDRESS=0xYourElsaSignerAddressHere


# -----------------------------------------------------------------------------
# ORACLE OPERATOR — Web2Oracle Trusted Operator
# -----------------------------------------------------------------------------

# Private key of the initial oracle operator wallet.
# This address receives ORACLE_OPERATOR_ROLE on the Web2Oracle contract.
# In production, rotate to a set of geographically distributed oracle nodes.
ORACLE_OPERATOR_PRIVATE_KEY=your_oracle_operator_private_key_here

# Address of the initial oracle operator wallet.
ORACLE_OPERATOR_ADDRESS=0xYourOracleOperatorAddressHere


# -----------------------------------------------------------------------------
# NETWORK — RPC ENDPOINTS
# -----------------------------------------------------------------------------

# Ethereum Mainnet
MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Ethereum Sepolia Testnet (primary testnet for this project)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Polygon Mainnet
POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Polygon Mumbai Testnet
MUMBAI_RPC_URL=https://polygon-mumbai.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Arbitrum One Mainnet
ARBITRUM_RPC_URL=https://arbitrum-mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Arbitrum Sepolia Testnet
ARBITRUM_SEPOLIA_RPC_URL=https://arbitrum-sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Base Mainnet
BASE_RPC_URL=https://mainnet.base.org

# Base Sepolia Testnet
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Local Hardhat Node (default — no change needed)
LOCALHOST_RPC_URL=http://127.0.0.1:8545


# -----------------------------------------------------------------------------
# RPC PROVIDER API KEYS
# -----------------------------------------------------------------------------

# Infura Project ID (used in RPC URLs above)
INFURA_PROJECT_ID=your_infura_project_id_here

# Alchemy API Key (alternative to Infura)
ALCHEMY_API_KEY=your_alchemy_api_key_here


# -----------------------------------------------------------------------------
# CONTRACT VERIFICATION
# -----------------------------------------------------------------------------

# Etherscan API key — used for verifying contracts on Ethereum mainnet & testnets.
# Get yours at: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Polygonscan API key — used for verifying contracts on Polygon networks.
# Get yours at: https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# Arbiscan API key — used for verifying contracts on Arbitrum networks.
# Get yours at: https://arbiscan.io/myapikey
ARBISCAN_API_KEY=your_arbiscan_api_key_here

# Basescan API key — used for verifying contracts on Base networks.
# Get yours at: https://basescan.org/myapikey
BASESCAN_API_KEY=your_basescan_api_key_here


# -----------------------------------------------------------------------------
# DEPLOYED CONTRACT ADDRESSES
# -----------------------------------------------------------------------------
# Populated automatically by the deploy script. Fill in manually if deploying
# contracts individually or referencing an existing deployment.

# ── Sepolia Testnet ──────────────────────────────────────────────────────────
SEPOLIA_DATA_TYPES_LIB=
SEPOLIA_AGENT_REGISTRY=
SEPOLIA_REPUTATION_ENGINE=
SEPOLIA_TASK_ESCROW=
SEPOLIA_AGENT_MARKETPLACE=
SEPOLIA_WEB2_ORACLE=
SEPOLIA_ELSA_ORCHESTRATOR=

# ── Polygon Mumbai Testnet ───────────────────────────────────────────────────
MUMBAI_AGENT_REGISTRY=
MUMBAI_REPUTATION_ENGINE=
MUMBAI_TASK_ESCROW=
MUMBAI_AGENT_MARKETPLACE=
MUMBAI_WEB2_ORACLE=
MUMBAI_ELSA_ORCHESTRATOR=

# ── Mainnet ──────────────────────────────────────────────────────────────────
MAINNET_AGENT_REGISTRY=
MAINNET_REPUTATION_ENGINE=
MAINNET_TASK_ESCROW=
MAINNET_AGENT_MARKETPLACE=
MAINNET_WEB2_ORACLE=
MAINNET_ELSA_ORCHESTRATOR=


# -----------------------------------------------------------------------------
# DEPLOYMENT PARAMETERS
# -----------------------------------------------------------------------------

# Initial maxBudgetCap for ElsaOrchestrator (in wei).
# Default: 0.1 ETH = 100000000000000000 wei
# Must be > 0 and <= 10 ETH (ABSOLUTE_MAX_BUDGET).
INITIAL_BUDGET_CAP_WEI=100000000000000000

# Gas price override in gwei (leave empty to use network suggested gas price).
# Example: 20 = 20 gwei
GAS_PRICE_GWEI=

# Gas limit override (leave empty to use estimated gas).
GAS_LIMIT=


# -----------------------------------------------------------------------------
# REPORT / ANALYTICS
# -----------------------------------------------------------------------------

# Set to "true" to enable gas usage reporting via hardhat-gas-reporter.
REPORT_GAS=false

# CoinMarketCap API key for USD gas cost estimation in reports.
# Get yours at: https://pro.coinmarketcap.com/account
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_here


# -----------------------------------------------------------------------------
# TESTING
# -----------------------------------------------------------------------------

# Fork block number for mainnet forking tests (leave empty for latest).
# Using a fixed block ensures reproducible test results.
FORK_BLOCK_NUMBER=

# Set to "true" to enable Solidity optimizer in tests (matches production).
OPTIMIZER_ENABLED=true

# Number of optimizer runs (higher = cheaper calls, more expensive deployment).
OPTIMIZER_RUNS=200
